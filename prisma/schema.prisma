generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH - Auth.js Prisma Adapter
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// USER
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  discordId         String  @unique
  discordUsername   String
  discordGlobalName String?
  discordAvatar    String?

  role              UserRole @default(USER)
  bio               String?  @db.Text
  preferredPosition String?
  tier              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  accounts          Account[]
  sessions          Session[]
  createdParties    Party[]            @relation("PartyCreator")
  partyMembers      PartyMember[]
  notifications     Notification[]
  characters        CharacterProfile[]
  matchingPreference MatchingPreference?
  bookmarks         PartyBookmark[]

  @@index([discordId])
}

enum UserRole {
  USER
  ADMIN
}

// ============================================================
// CHARACTER PROFILE
// ============================================================

model CharacterProfile {
  id          String  @id @default(cuid())
  userId      String
  name        String
  jobClass    String
  level       Int     @default(1)
  tier        String?
  spec        Json?
  description String? @db.Text
  isMain      Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// MATCHING PREFERENCE
// ============================================================

model MatchingPreference {
  id                 String  @id @default(cuid())
  userId             String  @unique
  isActive           Boolean @default(false)
  preferredGameModes Json?
  preferredTiers     Json?
  preferredPositions Json?
  minMembers         Int?
  maxMembers         Int?
  notifyOnMatch      Boolean @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// PARTY
// ============================================================

model Party {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  mode        PartyMode
  status      PartyStatus @default(RECRUITING)

  maxMembers   Int    @default(4)
  currentCount Int    @default(1)

  gameMode    String?
  tier        String?
  position    String?

  templateId   String?
  template     FormTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateData Json?

  creatorId   String
  creator     User @relation("PartyCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  discordChannelId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  members   PartyMember[]
  bookmarks PartyBookmark[]

  @@index([status, createdAt])
  @@index([creatorId])
  @@index([templateId])
  @@index([gameMode])
}

enum PartyMode {
  FREE_FORM
  TEMPLATE
}

enum PartyStatus {
  RECRUITING
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================================
// PARTY MEMBER
// ============================================================

model PartyMember {
  id        String            @id @default(cuid())
  partyId   String
  userId    String
  role      PartyMemberRole   @default(MEMBER)
  status    ApplicationStatus @default(PENDING)
  message   String?           @db.Text
  position  String?

  appliedAt   DateTime  @default(now())
  respondedAt DateTime?

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@index([partyId, status])
  @@index([userId])
}

enum PartyMemberRole {
  LEADER
  MEMBER
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

// ============================================================
// PARTY BOOKMARK
// ============================================================

model PartyBookmark {
  id      String @id @default(cuid())
  userId  String
  partyId String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@unique([userId, partyId])
  @@index([userId])
}

// ============================================================
// FORM TEMPLATE (Admin-managed)
// ============================================================

model FormTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fields  TemplateField[]
  parties Party[]

  @@index([isActive, sortOrder])
}

model TemplateField {
  id          String    @id @default(cuid())
  templateId  String
  label       String
  fieldType   FieldType
  placeholder String?
  isRequired  Boolean   @default(false)
  sortOrder   Int       @default(0)
  options     Json?
  validation  Json?

  template FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  RADIO
  CHECKBOX
  DATE
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?
  isRead    Boolean          @default(false)

  discordSent   Boolean   @default(false)
  discordSentAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

enum NotificationType {
  PARTY_APPLICATION
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  PARTY_FULL
  PARTY_CANCELLED
  MEMBER_LEFT
  MATCHING_FOUND
  SYSTEM
}
