# Discord Bot
DISCORD_BOT_TOKEN="your-bot-token"
DISCORD_GUILD_ID="your-discord-server-id"

# Cron
CRON_SECRET="your-cron-secret-token"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
